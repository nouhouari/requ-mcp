{
  "name": "requ-mcp",
  "version": "0.2.0",
  "description": "MCP server to track requirements coverage and its evolution across phases/releases. Pairs with Conductor for e2e tests; links scenarios to user stories via @US-xxx tags.",
  "type": "module",
  "bin": {
    "requ-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "smoke": "tsx scripts/smoke.ts",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "requirements",
    "traceability",
    "coverage",
    "cucumber",
    "conductor",
    "e2e"
  ],
  "author": "Nourreddine HOUARI <houarinourredine@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/nouhouari/requ-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nouhouari/requ-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nouhouari/requ-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
